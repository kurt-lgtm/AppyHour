# Cut Order Server — env vars
# Copy to .env for local dev; set in systemd EnvironmentFile for prod.

FLASK_SECRET_KEY=change-me-to-random-64-bytes
FLASK_ENV=development
APP_PASSWORD=change-me

# Phase 2+ (Shopify / Recharge)
SHOPIFY_SHOP=elevatefoods
SHOPIFY_ADMIN_TOKEN=shpat_xxx
SHOPIFY_API_VERSION=2026-04
RECHARGE_TOKEN=sk_xxx

# Phase 4 (LTF sheet via Google service account)
GOOGLE_SVC_ACCOUNT_JSON=/etc/cut-order/google-svc.json
LTF_SHEET_ID=1Obz-Ib6KsjhB83NiRlFFCLFk9UjHr_YZl8lONl6VzKw

# Phase 6 (DO Spaces)
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=cut-orders
DO_SPACES_KEY=
DO_SPACES_SECRET=

# Postgres
DATABASE_URL=postgresql+psycopg2://cutorder:CHANGEME@localhost:5432/cutorder
